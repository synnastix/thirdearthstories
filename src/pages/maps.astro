---
import Base from '../layouts/Base.astro';

const maps = [
  {
    title: 'Tellunis',
    description: 'A broad overview of known lands.',
    image: '/public/images/tellunis.jpg',
  },
  {
    title: 'Timbur Deep',
    description: 'Rough map of the Imperial capital.',
    image: '/public/images/timbur_deep.jpg',
  },
];
---

<Base title="Maps">
  <div class="page">
    <div class="hero">
      <p class="eyebrow">Cartography</p>
      <h1 class="page-title">Maps</h1>
      <p class="page-desc">Known surveys of the world. Accuracy not guaranteed.</p>
    </div>

    <div class="gallery">
      {maps.map((map, i) => (
        <div class="map-card" onclick={`openLightbox(${i})`}>
          <div class="map-thumb">
            <img src={`/thirdearthstories${map.image}`} alt={map.title} />
            <div class="map-overlay">
              <span class="map-zoom">View full size</span>
            </div>
          </div>
          <div class="map-info">
            <div class="map-title">{map.title}</div>
            <div class="map-desc">{map.description}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="lightbox" id="lightbox" onclick="closeLightbox()">
    <button class="lightbox-close" onclick="closeLightbox()">✕</button>
    <button class="lightbox-prev" onclick="event.stopPropagation(); changeMap(-1)">‹</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    <button class="lightbox-next" onclick="event.stopPropagation(); changeMap(1)">›</button>
    <div class="lightbox-caption" id="lightbox-caption"></div>
  </div>
</Base>

<style>
  .page { background: #f7f5f0; min-height: 100vh; display: flex; flex-direction: column; }

  .hero {
    background: #fff;
    border-bottom: 0.5px solid #ddd9d0;
    padding: 3rem 2rem 2.5rem;
  }
  .eyebrow {
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: .75rem;
  }
  .page-title {
    font-family: 'Crimson Pro', serif;
    font-size: 48px;
    font-weight: 300;
    line-height: 1.15;
    margin-bottom: .75rem;
  }
  .page-desc {
    font-size: 15px;
    line-height: 1.8;
    color: #666;
    font-style: italic;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
    padding: 2.5rem 2rem;
  }

  .map-card {
    background: #fff;
    border: 0.5px solid #ddd9d0;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
  }
  .map-card:hover .map-overlay { opacity: 1; }
  .map-card:hover img { transform: scale(1.02); }

  .map-thumb {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .map-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .map-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .map-zoom {
    color: #fff;
    font-size: 13px;
    letter-spacing: .08em;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.6);
    padding: 6px 16px;
    border-radius: 20px;
  }

  .map-info {
    padding: 1rem 1.25rem;
  }
  .map-title {
    font-family: 'Crimson Pro', serif;
    font-size: 20px;
    font-weight: 400;
    margin-bottom: .25rem;
  }
  .map-desc {
    font-size: 13px;
    color: #888;
    line-height: 1.6;
  }

  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }
  .lightbox.open { display: flex; }

  .lightbox-img {
    max-width: 90vw;
    max-height: 82vh;
    object-fit: contain;
    border-radius: 4px;
  }
  .lightbox-caption {
    color: rgba(255,255,255,0.6);
    font-size: 13px;
    margin-top: 1rem;
    letter-spacing: .04em;
  }
  .lightbox-close {
    position: fixed;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(255,255,255,0.7);
    font-size: 24px;
    cursor: pointer;
    line-height: 1;
  }
  .lightbox-close:hover { color: #fff; }

  .lightbox-prev, .lightbox-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgba(255,255,255,0.6);
    font-size: 48px;
    cursor: pointer;
    line-height: 1;
    padding: 0 1rem;
  }
  .lightbox-prev:hover, .lightbox-next:hover { color: #fff; }
  .lightbox-prev { left: 1rem; }
  .lightbox-next { right: 1rem; }

  @media (max-width: 640px) {
    .gallery { grid-template-columns: 1fr; padding: 1.5rem 1.25rem; }
    .hero { padding: 2rem 1.25rem 1.5rem; }
    .page-title { font-size: 36px; }
  }
</style>

<script>
  const maps = [
    { image: '/thirdearthstories/public/images/tellunis.jpg', title: 'Tellunis' },
    { image: '/thirdearthstories/public/images/timbur_deep.jpg', title: 'Timbur Deep' },
  ];

  let current = 0;

  window.openLightbox = function(index: number) {
    current = index;
    const lb = document.getElementById('lightbox')!;
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const caption = document.getElementById('lightbox-caption')!;
    img.src = maps[current].image;
    img.alt = maps[current].title;
    caption.textContent = maps[current].title;
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  window.closeLightbox = function() {
    document.getElementById('lightbox')!.classList.remove('open');
    document.body.style.overflow = '';
  }

  window.changeMap = function(dir: number) {
    current = (current + dir + maps.length) % maps.length;
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    const caption = document.getElementById('lightbox-caption')!;
    img.src = maps[current].image;
    img.alt = maps[current].title;
    caption.textContent = maps[current].title;
  }

  document.addEventListener('keydown', e => {
    const lb = document.getElementById('lightbox')!;
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') window.closeLightbox();
    if (e.key === 'ArrowLeft') window.changeMap(-1);
    if (e.key === 'ArrowRight') window.changeMap(1);
  });
</script>
