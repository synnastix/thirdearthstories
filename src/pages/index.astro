---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const entries = await getCollection('encyclopedia');

const tagColors: Record<string, { bg: string; color: string }> = {
  place:    { bg: '#EAF3DE', color: '#3B6D11' },
  faction:  { bg: '#EEEDFE', color: '#3C3489' },
  creature: { bg: '#FAECE7', color: '#993C1D' },
  lore:     { bg: '#FAEEDA', color: '#854F0B' },
  person:   { bg: '#E1F5EE', color: '#0F6E56' },
};

const counts = {
  place:    entries.filter(e => e.data.category === 'place').length,
  faction:  entries.filter(e => e.data.category === 'faction').length,
  creature: entries.filter(e => e.data.category === 'creature').length,
  lore:     entries.filter(e => e.data.category === 'lore').length,
  person:   entries.filter(e => e.data.category === 'person').length,
};
---
<Base title="Home">
  <div class="page">

    <div class="hero">
      <div>
        <p class="eyebrow">World compendium</p>
        <h1 class="site-title">Third Earth Stories</h1>
        <p class="site-desc">A living encyclopedia of places, peoples, and powers.</p>
        <div class="stats">
          <div class="stat"><span class="stat-num">{entries.length}</span><span class="stat-label">Total</span></div>
          <div class="stat"><span class="stat-num">{counts.place}</span><span class="stat-label">Places</span></div>
          <div class="stat"><span class="stat-num">{counts.faction}</span><span class="stat-label">Factions</span></div>
          <div class="stat"><span class="stat-num">{counts.creature}</span><span class="stat-label">Creatures</span></div>
          <div class="stat"><span class="stat-num">{counts.lore}</span><span class="stat-label">Lore</span></div>
          <div class="stat"><span class="stat-num">{counts.person}</span><span class="stat-label">People</span></div>
        </div>
      </div>
    </div>

    <div class="body">
      <aside class="sidebar">
        <div class="sidebar-section">
          <div class="sidebar-heading">Browse by type</div>
          <a class="sidebar-item" href="#" data-filter="all">All entries</a>
          <a class="sidebar-item" href="#" data-filter="place">Places</a>
          <a class="sidebar-item" href="#" data-filter="faction">Factions</a>
          <a class="sidebar-item" href="#" data-filter="creature">Creatures</a>
          <a class="sidebar-item" href="#" data-filter="lore">Lore &amp; magic</a>
          <a class="sidebar-item" href="#" data-filter="person">People</a>
        </div>
      </aside>

      <main class="main">
       <div class="search-bar">
        <input type="text" id="search" placeholder="Search entries…" autocomplete="off" />
        </div>
        <p class="section-label" id="section-label">All entries</p>
        <div class="grid" id="entry-grid">
          {entries.map(entry => {
            const tag = tagColors[entry.data.category] ?? { bg: '#eee', color: '#666' };
            return (
              <a href={`/thirdearthstories/encyclopedia/${entry.slug}`} class="card" data-category={entry.data.category} data-title={entry.data.title} data-lead={entry.data.lead}>
                <span class="tag" style={`background:${tag.bg};color:${tag.color};`}>{entry.data.category}</span>
                <div class="card-title">{entry.data.title}</div>
                <div class="card-desc">{entry.data.lead}</div>
              </a>
            );
          })}
        </div>
        <p class="no-results" id="no-results" style="display:none;">No entries found.</p>
      </main>
    </div>
  </div>
</Base>

<style>
 .page {
  background: #f7f5f0;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.search-bar {
  margin-bottom: 1rem;
}
.search-bar input {
  width: 100%;
  padding: 8px 12px;
  font-size: 14px;
  border: 0.5px solid #ddd9d0;
  border-radius: 8px;
  background: #fff;
  color: #1a1a18;
  font-family: 'Inter', sans-serif;
}
.search-bar input:focus {
  outline: none;
  border-color: #aaa;
}
.no-results {
  font-size: 13px;
  color: #aaa;
  padding: 1rem 0;
}

.body {
  display: grid;
  grid-template-columns: 200px 1fr;
  flex: 1;
}
  .hero {
    background: #fff;
    border-bottom: 0.5px solid #ddd9d0;
    padding: 3rem 2rem 2.5rem;
  }
  .eyebrow {
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: .75rem;
  }
  .site-title {
    font-family: 'Crimson Pro', serif;
    font-size: 48px;
    font-weight: 300;
    line-height: 1.15;
    margin-bottom: .75rem;
  }
  .site-desc {
    font-size: 15px;
    line-height: 1.8;
    color: #666;
    max-width: 520px;
    margin-bottom: 1.75rem;
  }
  .stats { display: flex; gap: 2rem; }
  .stat { display: flex; flex-direction: column; }
  .stat-num {
    font-family: 'Crimson Pro', serif;
    font-size: 28px;
    font-weight: 300;
  }
  .stat-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: #999;
    margin-top: 2px;
  }

  .sidebar {
    background: #fff;
    border-right: 0.5px solid #ddd9d0;
    padding: 1.5rem 0;
    position: sticky;
    top: 52px;
  }
  .sidebar-heading {
    font-size: 10px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #aaa;
    padding: 0 1.25rem;
    margin-bottom: .5rem;
  }
  .sidebar-item {
    display: block;
    padding: .35rem 1.25rem;
    font-size: 13px;
    color: #666;
    text-decoration: none;
    border-left: 2px solid transparent;
  }
  .sidebar-item:hover { color: #1a1a18; background: #f7f5f0; }
  .sidebar-item.active {
    color: #1a1a18;
    background: #f7f5f0;
    border-left-color: #1a1a18;
    padding-left: calc(1.25rem - 2px);
  }

  .main { padding: 2rem 2.5rem; }
  .section-label {
    font-size: 11px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 1rem;
    padding-bottom: .5rem;
    border-bottom: 0.5px solid #ddd9d0;
  }

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
}
.card {
  background: #fff;
  padding: 1.25rem;
  display: block;
  text-decoration: none;
  color: inherit;
  border: 0.5px solid #ddd9d0;
  border-radius: 12px;
}
.card:hover { background: #faf8f4; }
.card.hidden { display: none; }

  .tag {
    display: inline-block;
    font-size: 10px;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 20px;
    margin-bottom: .6rem;
  }
  .card-title {
    font-family: 'Crimson Pro', serif;
    font-size: 18px;
    margin-bottom: .3rem;
    line-height: 1.2;
  }
  .card-desc {
    font-size: 12px;
    color: #888;
    line-height: 1.6;
  }
@media (max-width: 640px) {
  .body {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: static;
    height: auto;
    border-right: none;
    border-bottom: 0.5px solid #ddd9d0;
    padding: 1rem 0;
  }

  .main {
    padding: 1.5rem 1.25rem;
  }

  .hero {
    padding: 2rem 1.25rem 1.5rem;
  }

  .site-title {
    font-size: 36px;
  }
}
</style>

<script>
  function initSearch() {
    const cards = Array.from(document.querySelectorAll('.card')) as HTMLElement[];
    const searchInput = document.getElementById('search') as HTMLInputElement;
    const label = document.getElementById('section-label')!;
    const noResults = document.getElementById('no-results')!;
    const sidebarItems = document.querySelectorAll('.sidebar-item') as NodeListOf<HTMLElement>;

    const labels: Record<string, string> = {
      all: 'All entries', place: 'Places', faction: 'Factions',
      creature: 'Creatures', lore: 'Lore & magic', person: 'People',
    };

    let activeFilter = 'all';

    function matchesSearch(card: HTMLElement, query: string): boolean {
      if (!query) return true;
      const text = `${card.dataset.title} ${card.dataset.lead} ${card.dataset.category}`.toLowerCase();
      return text.includes(query.toLowerCase());
    }

    function update() {
      const query = searchInput.value.trim();
      let visibleCount = 0;

      cards.forEach(card => {
        const matchType = activeFilter === 'all' || card.dataset.category === activeFilter;
        const matchSearch = matchesSearch(card, query);
        const show = matchType && matchSearch;
        card.classList.toggle('hidden', !show);
        if (show) visibleCount++;
      });

      if (query) {
        label.textContent = `Results for "${query}"`;
      } else {
        label.textContent = labels[activeFilter] ?? 'All entries';
      }

      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    }

    function filter(type: string) {
      activeFilter = type;
      sidebarItems.forEach(item => {
        item.classList.toggle('active', item.dataset.filter === type);
      });
      update();
    }

    searchInput.addEventListener('input', update);
    sidebarItems.forEach(item => {
      item.addEventListener('click', e => {
        e.preventDefault();
        filter((item as HTMLElement).dataset.filter ?? 'all');
      });
    });

    filter('all');
  }

  initSearch();
</script>
