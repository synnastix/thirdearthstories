---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const entries = await getCollection('encyclopedia');
---
<Base title="Home">
  <div style="max-width: 900px; margin: 0 auto; padding: 3rem 2rem;">
    <p style="font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#999;margin-bottom:.75rem;">World compendium</p>
    <h1 style="font-family:'Crimson Pro',serif;font-size:48px;font-weight:300;margin-bottom:1rem;">Third Earth Stories</h1>
    <p style="font-size:15px;line-height:1.8;color:#666;max-width:520px;margin-bottom:2.5rem;">A living encyclopedia of places, peoples, and powers.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1px;background:#ddd9d0;border:0.5px solid #ddd9d0;border-radius:12px;overflow:hidden;">
      {entries.map(entry => (
        <a href={`/encyclopedia/${entry.slug}`} style="background:#fff;padding:1.25rem;display:block;">
          <span style="font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:2px 8px;border-radius:20px;background:#eee;color:#666;display:inline-block;margin-bottom:.6rem;">{entry.data.category}</span>
          <div style="font-family:'Crimson Pro',serif;font-size:18px;margin-bottom:.3rem;">{entry.data.title}</div>
          <div style="font-size:12px;color:#888;line-height:1.6;">{entry.data.lead}</div>
        </a>
      ))}
    </div>
  </div>
</Base>
