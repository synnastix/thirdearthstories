---
import Base from '../layouts/Base.astro';
---
<Base title="About">
  <div style="max-width:740px;margin:3rem auto;padding:0 2rem;">
    <p style="font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#999;margin-bottom:.75rem;">About</p>
    <h1 style="font-family:'Crimson Pro',serif;font-size:40px;font-weight:300;margin-bottom:1rem;">Third Earth Stories</h1>
    <p style="font-size:15px;line-height:1.8;color:#666;">Write whatever you want here about the world, the stories, yourself as the author — whatever feels right.</p>
  </div>
</Base>
